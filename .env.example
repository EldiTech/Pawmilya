# Frontend (Expo) environment variables
# Copy this file to .env and adjust based on your setup.

# Local backend on the same machine (web/simulator)
# EXPO_PUBLIC_API_URL=http://localhost:3000/api

# Android emulator backend
# EXPO_PUBLIC_API_URL=http://10.0.2.2:3000/api

# Physical device on same Wi-Fi
# EXPO_PUBLIC_API_URL=http://192.168.1.100:3000/api

# Deployed backend (recommended for teams on different networks)
EXPO_PUBLIC_API_URL=https://your-api-domain.com/api
